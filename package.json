{
  "name": "nightops",
  "version": "0.1.0",
  "private": true,
  "description": "CLI development companion for CodexCLI",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:electron": "electron .",
    "build": "vite build",
    "pack:mac": "npm run build && electron-builder --mac dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "postinstall": "node scripts/ensure-node-pty-permissions.mjs",
    "preview": "vite preview",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "start": "electron ."
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "systeminformation": "^5.27.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^36.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.19",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "local.nightops.app",
    "productName": "NightOps",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "src/utils/**",
      "package.json",
      "node_modules/**",
      "scripts/ensure-node-pty-permissions.mjs"
    ],
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "mac": {
      "identity": null,
      "target": [
        "dir"
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
